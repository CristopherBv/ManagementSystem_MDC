<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<StackPane stylesheets="@../css/styles.css" styleClass="fondo-pantalla-inmersiva"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="gestionmats.controllers.LoginController">

    <VBox styleClass="tarjeta-login" alignment="CENTER" spacing="25.0" maxWidth="320" maxHeight="340">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
        </padding>

        <VBox alignment="CENTER" spacing="5.0">
            <Text text="Bienvenido" styleClass="titulo-principal"/>
            <Text text="Sistema de Gestión" styleClass="subtitulo"/>
        </VBox>

        <VBox spacing="8.0">
            <Label text="Usuario" styleClass="etiqueta"/>
            <TextField fx:id="txtUsername" promptText="ej. cristo123" styleClass="input-texto"/>
        </VBox>

        <VBox spacing="8.0">
            <Label text="Contraseña" styleClass="etiqueta"/>
            <PasswordField fx:id="txtPassword" promptText="••••••••" styleClass="input-texto"/>
        </VBox>

        <Button text="Ingresar" onAction="#handleLogin" styleClass="btn-principal" prefWidth="260"/>

        <Label fx:id="lblError" text="" styleClass="etiqueta-error" wrapText="true" minHeight="20"/>
    </VBox>
</StackPane>